# Cloudflare Workers Secrets として登録する変数
# 実際の値は `npx wrangler secret put <NAME>` で設定する

SWITCHBOT_TOKEN=
SWITCHBOT_SECRET=
AC_DEVICE_ID=

# JSON文字列で複数照明を登録する。id は任意のキー、labelはUI表示名。
# 例: LIGHT_DEVICES={"60w_light":{"deviceId":"xxxxxxxxxxxx","label":"60w_light"},"100w_light":{"deviceId":"xxxxxxxxxxxx","label":"100w_light"}}
LIGHT_DEVICES=
