# Cloudflare Workers Secrets として登録する変数
# 実際の値は `npx wrangler secret put <NAME>` で設定する

SWITCHBOT_TOKEN=
SWITCHBOT_SECRET=
AC_DEVICE_ID=

# JSON文字列で複数のプラグを登録する。id は任意のキー、labelはUI表示名。
# 例: PLUG_DEVICES={"60w_light":{"deviceId":"xxxxxxxxxxxx","label":"60w_light"},"100w_light":{"deviceId":"xxxxxxxxxxxx","label":"100w_light"}}
PLUG_DEVICES=

# JSON文字列で赤外線リモコンの照明を登録する（Hub経由でturnOn/turnOff/brightnessUp/brightnessDownに対応）。
# 例: IR_LIGHTS={"living_ir_light":{"deviceId":"xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx","label":"リビング照明"}}
IR_LIGHTS=
